{
  "yaml.schemas": {
    "file:///home/brookeb/.vscode/extensions/atlassian.atlascode-3.0.6/resources/schemas/pipelines-schema.json": "bitbucket-pipelines.yml",
    "https://raw.githubusercontent.com/moonrepo/moon/master/website/static/schemas/project.json": "file:///workspace/.moon/tasks/node.yml"
  },
  // Flatpak VS Code: Docker/Podman paths for host access
  // These paths allow Flatpak VS Code to access Docker on the host system
  "docker.dockerPath": "/run/host/usr/bin/docker",
  "dev.containers.dockerPath": "/run/host/usr/bin/docker",
  "dev.containers.dockerComposePath": "/run/host/usr/bin/docker-compose",
  // Terminal profile for accessing host Docker via flatpak-spawn
  "terminal.integrated.profiles.linux": {
    "flatpak-host": {
      "path": "/usr/bin/flatpak-spawn",
      "args": ["--host", "bash"],
      "icon": "terminal-linux",
      "overrideName": true
    }
  }
}